{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OneSDK Mapping Schema",
  "description": "Schema for onesdk.json - maps OneSDK versions to channel versions",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional relative schema reference"
    }
  },
  "patternProperties": {
    "^[0-9]+\\.[0-9]+\\.[0-9]+$": {
      "type": "object",
      "required": ["release_date", "channels"],
      "properties": {
        "release_date": {
          "type": "string",
          "format": "date",
          "description": "Release date in YYYY-MM-DD format"
        },
        "channels": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["version", "zip_url", "md5"],
              "properties": {
                "version": {
                  "type": "string",
                  "description": "Channel SDK version"
                },
                "zip_url": {
                  "type": "string",
                  "format": "uri",
                  "description": "COS/CDN URL to download the ZIP package"
                },
                "md5": {
                  "type": "string",
                  "description": "ZIP file MD5"
                }
              },
              "additionalProperties": true
            }
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
