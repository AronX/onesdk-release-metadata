{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OneSDK Mapping Schema",
  "description": "Schema for onesdk.json - maps OneSDK versions to channel versions",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "required": ["release_date", "channels"],
    "properties": {
      "release_date": {
        "type": "string",
        "format": "date",
        "description": "Release date in YYYY-MM-DD format"
      },
      "channels": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "required": ["version", "zip_url"],
          "properties": {
            "version": {
              "type": "string",
              "description": "Channel SDK version"
            },
            "zip_url": {
              "type": "string",
              "format": "uri",
              "description": "COS/CDN URL to download the ZIP package"
            },
            "size_bytes": {
              "type": "integer",
              "description": "ZIP file size in bytes"
            }
          }
        }
      }
    }
  }
}
