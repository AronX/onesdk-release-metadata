{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OneSDK Version Mapping Schema",
  "description": "Schema for a single OneSDK version mapping file",
  "type": "object",
  "required": ["version", "release_date", "channels"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "release_date": {
      "type": "string",
      "format": "date"
    },
    "channels": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["version", "zip_url", "md5"],
          "properties": {
            "version": {
              "type": "string"
            },
            "zip_url": {
              "type": "string",
              "format": "uri"
            },
            "md5": {
              "type": "string"
            },
            "release_date": {
              "type": "string",
              "format": "date"
            },
            "release_note": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ]
            }
          },
          "additionalProperties": true
        }
      }
    }
  },
  "additionalProperties": false
}
